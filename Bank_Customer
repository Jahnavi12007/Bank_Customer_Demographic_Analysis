43.	# ================================
44.	# STEP 5: VISUALIZATION (MATPLOTLIB ONLY)
45.	# ================================
46.	
47.	# Age Distribution
48.	plt.hist(data['Age'], bins=5)
49.	plt.title("Age Distribution")
50.	plt.xlabel("Age")
51.	plt.ylabel("Count")
52.	plt.show()
53.	
54.	# Gender Distribution
55.	gender_counts = data['Gender'].value_counts()
56.	plt.bar(gender_counts.index, gender_counts.values)
57.	plt.title("Gender Distribution")
58.	plt.xlabel("Gender")
59.	plt.ylabel("Count")
60.	plt.show()
61.	
62.	# ================================
63.	# STEP 6: CUSTOMER SEGMENTATION
64.	# ================================
65.	
66.	data['Age_Group'] = pd.cut(
67.	    data['Age'],
68.	    bins=[18, 30, 45, 60],
69.	    labels=['Young', 'Adult', 'Senior']
70.	)
71.	
72.	group_data = data.groupby('Age_Group')['Balance'].mean()
73.	
74.	print("\n--- BALANCE BY AGE GROUP ---")
75.	print(group_data)
76.	
77.	plt.bar(group_data.index.astype(str), group_data.values)
78.	plt.title("Balance by Age Group")
79.	plt.xlabel("Age Group")
80.	plt.ylabel("Balance")
81.	plt.show()
82.	
