5.	import pandas as pd
6.	import numpy as np
7.	import matplotlib.pyplot as plt
8.	
9.	# ================================
10.	# STEP 1: CREATE DATASET
11.	# ================================
12.	
13.	data = pd.DataFrame({
14.	    'Age': [22, 35, 45, 52, 23, 40, 28, 33, 50, 27],
15.	    'Gender': ['Male', 'Female', 'Male', 'Female', 'Male', 'Female', 'Male', 'Female', 'Male', 'Female'],
16.	    'Balance': [2000, 5000, 7000, 10000, 3000, 8000, 4000, 6000, 9000, 3500],
17.	    'Income': [25000, 50000, 60000, 70000, 30000, 65000, 35000, 48000, 72000, 32000],
18.	    'Loan': ['No', 'Yes', 'No', 'Yes', 'No', 'Yes', 'No', 'Yes', 'Yes', 'No'],
19.	    'Transactions': [15, 30, 25, 20, 18, 28, 22, 26, 19, 24]
20.	})
21.	
22.	# ================================
23.	# STEP 2: PREVIEW DATA
24.	# ================================
25.	
26.	print("\n--- DATASET PREVIEW ---")
27.	print(data.head())
28.	
